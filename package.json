{
  "name": "mini-agent",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Educational rebuild of a Pi-style agent loop (Phases 1–3)",
  "scripts": {
    "start": "tsx src/cli.ts",
    "tui": "tsx src/tui/main.ts",
    "tui:ink": "tsx src/tui/ink-main.tsx",
    "dev": "concurrently -k \"npm:dev:server\" \"npm:dev:web\"",
    "dev:server": "tsx watch src/server.ts",
    "dev:web": "vite --config web/vite.config.ts",
    "serve": "tsx src/server.ts",
    "build": "npm run typecheck && vite build --config web/vite.config.ts",
    "test": "tsx --test test/*.test.ts",
    "typecheck": "tsc --noEmit && tsc -p web/tsconfig.json --noEmit"
  },
  "engines": {
    "node": ">=18"
  },
  "overrides": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/multer": "^2.2.0",
    "@types/node": "^22.13.10",
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.1",
    "@types/supertest": "^7.2.1",
    "@vitejs/plugin-react": "^4.7.0",
    "concurrently": "^9.2.4",
    "supertest": "^7.2.2",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vite": "^6.4.3"
  },
  "dependencies": {
    "docx": "^9.5.1",
    "express": "^5.2.1",
    "ink": "^5.2.0",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "lucide-react": "^0.469.0",
    "mammoth": "^1.8.0",
    "multer": "^2.2.0",
    "pdf-lib": "^1.17.1",
    "pdf-parse": "^1.1.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^10.1.0",
    "rehype-sanitize": "^6.0.0"
  }
}
